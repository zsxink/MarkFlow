    "test:e2e:regression": "node e2e/run.mjs regression",
    "preview": "vite preview",
    "tauri": "tauri",
    "analyze": "npx vite build --mode analyze",
    "check-size": "bash scripts/check-bundle-size.sh",
    "benchmark:file-tree": "node scripts/file-tree-benchmark.mjs",
    "postinstall": "patch-package"
  },
