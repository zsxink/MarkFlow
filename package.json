{
  "name": "markflow",
  "private": true,
  "version": "0.0.6",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:e2e:build": "tauri build --debug --features e2e --config src-tauri/tauri.e2e.conf.json",
