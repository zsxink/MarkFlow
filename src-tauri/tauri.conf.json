{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "MarkFlow",
  "version": "0.0.6",
  "identifier": "com.markflow.editor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MarkFlow",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "capabilities": ["main-capability", "plantuml-http-capability"],
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' asset: http://asset.localhost https: data:; script-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$HOME/**/*.png", "$HOME/**/*.jpg", "$HOME/**/*.jpeg", "$HOME/**/*.gif", "$HOME/**/*.webp", "$HOME/**/*.svg", "$HOME/**/*.bmp"],
          "deny": []
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "dmg", "appimage", "deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": true,
        "languages": ["SimpChinese", "English"]
      },
      "wix": {
        "language": ["zh-CN"]
      }
    },
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "contentTypes": ["net.daringfireball.markdown"],
        "name": "Markdown Document",
        "mimeType": "text/markdown",
        "description": "Markdown 文件",
        "role": "Editor"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {}
  },
  "plugins": {
    "shell": {
      "open": "((mailto:.+)|(tel:.+)|(https?://.+)|(/.*)|([a-zA-Z]:\\\\.*))"
    }
  }
}
