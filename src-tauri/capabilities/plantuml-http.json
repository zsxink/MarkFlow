{
  "identifier": "plantuml-http-capability",
  "description": "HTTP access for PlantUML rendering",
  "windows": ["main"],
  "permissions": [
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        { "url": "https://**" },
        { "url": "http://**" }
      ]
    }
  ]
}
